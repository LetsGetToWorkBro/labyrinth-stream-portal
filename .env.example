# labyrinth-stream-portal environment variables
# This is a static HTML/JS site deployed on Cloudflare Pages.
# There is no build step that processes .env — these are for documentation.
#
# All values are hardcoded in supabase-portal.js (see that file).
# The anon key is intentionally public — Supabase RLS policies control access.

# ─── Supabase (Unified Auth) ──────────────────────────────────────────────────
# Same project as app.labyrinth.vision.
# The shared sb-* session cookie on .labyrinth.vision domain enables SSO.
#
# Update these in supabase-portal.js if the project ever changes:
SUPABASE_URL=https://bphlwgixwqxxsqsiuzpk.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Google Apps Script (GAS) — still used for schedule and recordings ────────
# The GAS_URL is hardcoded at the top of the inline <script> in index.html.
# Schedule data, recordings, and check-ins still flow through GAS.
# Stream status is now dual-sourced: Supabase (stream_status table) + GAS fallback.
GAS_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
